{
  "name": "purchasing-software",
  "version": "1.0.0",
  "description": "Einkäufer-Bestellverwaltungssystem",
  "type": "module",
  "main": "src/backend/server.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "node --watch src/backend/server.js",
    "dev:frontend": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src --fix",
    "format": "prettier --write src"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "@vercel/postgres": "^0.10.0",
    "express": "^4.18.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.32.2",
    "prettier": "^3.1.0",
    "vite": "^5.0.8"
  }
}
